# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.eggs/
.venv/
build/
dist/

# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Editors
.idea/
.vscode/
*.swp

# Caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Data and results (regenerable; do not commit)
data/flybrain/raw/
data/flybrain/*.fbg
data/flybrain/*.pt
data/traces/*
# Allow PLAN.md §616 cherry-picked traces (Phase 11 deliverable).
!data/traces/sample/
data/cache/
data/experiments/**/yandex_cache.sqlite
data/experiments/**/openrouter_cache.sqlite
data/experiments/*_run.log
results/
# Synthetic-source graphs are regenerated by `flybrain-py build`.
data/graphs/synthetic_*

# Local secrets
.env
.env.local

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/.terraform.lock.hcl
runs/
data/flybrain/*.node_metadata.json
