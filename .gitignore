# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.eggs/
.venv/
build/
dist/

# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Editors
.idea/
.vscode/
*.swp

# Caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Data and results (regenerable; do not commit)
data/flybrain/raw/
data/flybrain/*.fbg
data/flybrain/*.pt
# Round-10 null priors: small (~4 KB each) deterministic artefacts derived
# from the canonical FlyWire K=64 prior via scripts/build_null_priors.py.
# Committed so the prior-ablation suite is reproducible without
# re-downloading the 813 MB Zenodo source data.
!data/flybrain/null_priors/*.fbg
!data/flybrain/null_priors/provenance.json
data/traces/*
# Allow PLAN.md §616 cherry-picked traces (Phase 11 deliverable).
!data/traces/sample/
data/cache/
data/experiments/**/yandex_cache.sqlite
data/experiments/**/openrouter_cache.sqlite
data/experiments/*_run.log
results/
# Synthetic-source graphs are regenerated by `flybrain-py build`.
data/graphs/synthetic_*

# Local secrets
.env
.env.local

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/.terraform.lock.hcl
runs/
data/flybrain/*.node_metadata.json
