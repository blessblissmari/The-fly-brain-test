# Per-environment vars (contain real cloud IDs / billing IDs).
terraform.tfvars
*.tfvars.local

# State + lock files (we don't ship a state backend with this skeleton;
# initialize a remote backend or commit the lock file in your fork).
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
